{
    "ConnectionStrings": {
        "RoutingDb": "Host=localhost;Database=money_routing_test;Username=postgres",
        "DundukDb": "Host=localhost;Database=money_dunduk_test;Username=postgres",
        "FundukDb": "Host=localhost;Database=money_funduk_test;Username=postgres",
        "BurundukDb": "Host=localhost;Database=money_burunduk_test;Username=postgres"
    },
    "Sharding": {
        "VirtualNodes": 150,
        "Shards": [
            { "Name": "DundukDb", "ConnectionName": "DundukDb" },
            { "Name": "FundukDb", "ConnectionName": "FundukDb" },
            { "Name": "BurundukDb", "ConnectionName": "BurundukDb" }
        ]
    },
    "EmailSender": {
        "ProcessingInterval": "00:00:05",
        "MaxRetries": 5,
        "RetryBaseDelaySeconds": 3,
        "MaxBatchSize": 200,
        "MaxDegreeOfParallelism": 8
    }
}
