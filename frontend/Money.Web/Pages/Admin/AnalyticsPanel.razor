@page "/admin/analytics"
@using Money.ApiClient
@using Money.Web.Components.Charts
@attribute [Authorize]

<PageTitle>Аналитика</PageTitle>

<MudText Typo="Typo.h5"
         GutterBottom>Аналитика
</MudText>

@if (_stats == null && _metricsPerMinute == null && _slowEndpoints == null && _cubeExpenses == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-4 mb-6"
              Elevation="2">
        <MudStack Row
                  Justify="Justify.SpaceBetween"
                  AlignItems="AlignItems.Center"
                  Class="mb-3">
            <MudText Typo="Typo.h6">Таблицы ClickHouse</MudText>
            @if (_stats?.LastSyncUtc != null)
            {
                <MudText Typo="Typo.caption"
                         Class="mud-text-secondary">
                    Последняя синхронизация: @_stats.LastSyncUtc.Value.ToLocalTime().ToString("HH:mm:ss")
                </MudText>
            }
            <MudChip T="string"
                     Size="Size.Small"
                     Variant="Variant.Outlined"
                     Color="Color.Default"
                     Icon="@Icons.Material.Rounded.Refresh">
                Обновление каждые 30 сек
            </MudChip>
        </MudStack>

        @if (_stats?.Tables is { Count: > 0 })
        {
            <MudDataGrid T="AdminClient.ClickHouseTableInfo"
                         Items="_stats.Tables"
                         Dense
                         Hover
                         SortMode="SortMode.Multiple"
                         Elevation="0">
                <Columns>
                    <PropertyColumn Property="t => t.Name"
                                    Title="Таблица"
                                    Sortable="true" />
                    <TemplateColumn Title="Строк"
                                    SortBy="@(t => t.Rows)"
                                    Sortable="true">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">@context.Item.Rows.ToString("N0")</MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Размер"
                                    SortBy="@(t => t.Bytes)"
                                    Sortable="true">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">@FormatBytes(context.Item.Bytes)</MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="t => t.Partitions"
                                    Title="Партиции"
                                    Sortable="true" />
                </Columns>
            </MudDataGrid>
        }
        else
        {
            <MudText Typo="Typo.body2"
                     Class="mud-text-secondary">Нет данных
            </MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mb-6"
              Elevation="2">
        <MudText Typo="Typo.h6"
                 GutterBottom>API-запросы в минуту (последние 30 мин)
        </MudText>

        @if (_metricsPerMinute?.Count > 0)
        {
            <Chart Config="@_chartConfig"
                   @ref="_chart" />
        }
        else
        {
            <MudText Typo="Typo.body2"
                     Class="mud-text-secondary">Нет данных за последние 30 минут
            </MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mb-6"
              Elevation="2">
        <MudText Typo="Typo.h6"
                 GutterBottom>Top-10 медленных endpoint'ов
        </MudText>

        @if (_slowEndpoints is { Count: > 0 })
        {
            <MudDataGrid T="AdminClient.SlowEndpointInfo"
                         Items="_slowEndpoints"
                         Dense
                         Hover
                         SortMode="SortMode.Multiple"
                         Elevation="0">
                <Columns>
                    <PropertyColumn Property="e => e.Endpoint"
                                    Title="Endpoint"
                                    Sortable="true" />
                    <TemplateColumn Title="Avg (мс)"
                                    SortBy="@(e => e.AvgDurationMs)"
                                    Sortable="true">
                        <CellTemplate>
                            <MudText Typo="Typo.body2"
                                     Color="@(context.Item.AvgDurationMs > 500 ? Color.Warning : Color.Default)">
                                @context.Item.AvgDurationMs.ToString("F1")
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="P95 (мс)"
                                    SortBy="@(e => e.P95DurationMs)"
                                    Sortable="true">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">@context.Item.P95DurationMs.ToString("F1")</MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Error rate"
                                    SortBy="@(e => e.ErrorRatePercent)"
                                    Sortable="true">
                        <CellTemplate>
                            <MudText Typo="Typo.body2"
                                     Color="@(context.Item.ErrorRatePercent > 5 ? Color.Error : Color.Default)">
                                @context.Item.ErrorRatePercent.ToString("F1")%
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        }
        else
        {
            <MudText Typo="Typo.body2"
                     Class="mud-text-secondary">Нет данных
            </MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-4 mb-6"
              Elevation="2">
        <MudStack Row
                  Justify="Justify.SpaceBetween"
                  AlignItems="AlignItems.Center"
                  Class="mb-3">
            <MudText Typo="Typo.h6">OLAP-аналитика (Cube.dev)</MudText>
            <MudChip T="string"
                     Size="Size.Small"
                     Variant="Variant.Outlined"
                     Color="Color.Default"
                     Icon="@Icons.Material.Rounded.Refresh">
                Обновление каждые 30 сек
            </MudChip>
        </MudStack>

        <MudTabs @bind-ActivePanelIndex="_olapTab"
                 Rounded
                 Border
                 ApplyEffectsToContainer
                 Class="mb-3">
            <MudTabPanel Text="Расходы">
                @if (_cubeExpenses?.Data is { Count: > 0 })
                {
                    <MudDataGrid T="Dictionary<string, object?>"
                                 Items="_cubeExpenses.Data"
                                 Dense
                                 Hover
                                 Elevation="0"
                                 Class="mt-2">
                        <Columns>
                            <TemplateColumn Title="Категория">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2">@GetValue(context.Item, "operations.category_name")</MudText>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Сумма">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2">@GetValue(context.Item, "operations.total_sum")</MudText>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Кол-во">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2">@GetValue(context.Item, "operations.count")</MudText>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                }
                else
                {
                    <MudText Typo="Typo.body2"
                             Class="mud-text-secondary mt-2">@(_cubeExpenses == null ? "Загрузка..." : "Нет данных")</MudText>
                }
            </MudTabPanel>

            <MudTabPanel Text="Долги">
                @if (_cubeDebts?.Data is { Count: > 0 })
                {
                    <MudDataGrid T="Dictionary<string, object?>"
                                 Items="_cubeDebts.Data"
                                 Dense
                                 Hover
                                 Elevation="0"
                                 Class="mt-2">
                        <Columns>
                            <TemplateColumn Title="Владелец">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2">@GetValue(context.Item, "debts.owner_name")</MudText>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Долг">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2">@GetValue(context.Item, "debts.total_debt")</MudText>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Выплачено">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2">@GetValue(context.Item, "debts.total_paid")</MudText>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Остаток">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2">@GetValue(context.Item, "debts.outstanding")</MudText>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                }
                else
                {
                    <MudText Typo="Typo.body2"
                             Class="mud-text-secondary mt-2">@(_cubeDebts == null ? "Загрузка..." : "Нет данных")</MudText>
                }
            </MudTabPanel>

            <MudTabPanel Text="Тренды">
                @if (_cubeTrends?.Data is { Count: > 0 })
                {
                    <Chart Config="@_trendsChartConfig"
                           @ref="_trendsChart" />
                }
                else
                {
                    <MudText Typo="Typo.body2"
                             Class="mud-text-secondary mt-2">@(_cubeTrends == null ? "Загрузка..." : "Нет данных")</MudText>
                }
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
}
