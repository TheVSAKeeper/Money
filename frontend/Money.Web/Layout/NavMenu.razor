<MudNavMenu>
    <AuthorizeView>
        <Authorized>
            <MudNavGroup Expanded
                         Icon="@Icons.Material.Rounded.Money"
                         Title="Операции">
                <MudNavLink Href="operations"
                            Icon="@Icons.Material.Rounded.List"
                            Match="NavLinkMatch.Prefix">
                    Список
                </MudNavLink>
                <MudNavLink Href="statistics"
                            Icon="@Icons.Material.Rounded.PieChart"
                            Match="NavLinkMatch.Prefix">
                    Статистика
                </MudNavLink>
                <MudNavLink Href="categories"
                            Icon="@Icons.Material.Rounded.Category"
                            Match="NavLinkMatch.Prefix">
                    Категории
                </MudNavLink>
                <MudNavLink Href="fast-operations"
                            Icon="@Icons.Material.Rounded.FlashOn"
                            Match="NavLinkMatch.Prefix">
                    Быстрые
                </MudNavLink>
                <MudNavLink Href="regular-operations"
                            Icon="@Icons.Material.Rounded.Repeat"
                            Match="NavLinkMatch.Prefix">
                    Регулярные
                </MudNavLink>
            </MudNavGroup>

            <MudNavLink Href="debts"
                        Icon="@Icons.Material.Rounded.AttachMoney"
                        Match="NavLinkMatch.Prefix">
                Долги
            </MudNavLink>

            <MudNavLink Href="cars"
                        Icon="@Icons.Material.Rounded.ElectricCar"
                        Match="NavLinkMatch.Prefix">
                Авто
            </MudNavLink>

            <MudNavGroup Icon="@Icons.Material.Rounded.AdminPanelSettings"
                         Title="Администрирование"
                         Expanded="@_currentUrl.StartsWith("admin", StringComparison.Ordinal)">
                <MudNavLink Href="admin"
                            Icon="@Icons.Material.Rounded.Dashboard"
                            Match="NavLinkMatch.All">
                    Дашборд
                </MudNavLink>
                <MudNavLink Href="admin/sharding"
                            Icon="@Icons.Material.Rounded.Storage"
                            Match="NavLinkMatch.Prefix">
                    Шардирование
                </MudNavLink>
                <MudNavLink Href="admin/caching"
                            Icon="@Icons.Material.Rounded.Speed"
                            Match="NavLinkMatch.Prefix">
                    Кэширование
                </MudNavLink>
                <MudNavLink Href="admin/pubsub"
                            Icon="@Icons.Material.Rounded.CellTower"
                            Match="NavLinkMatch.Prefix">
                    Pub/Sub
                </MudNavLink>
                <MudNavLink Href="admin/email-queue"
                            Icon="@Icons.Material.Rounded.Email"
                            Match="NavLinkMatch.Prefix">
                    Очередь email
                </MudNavLink>
            </MudNavGroup>

            <MudNavLink Href="settings"
                        Icon="@Icons.Material.Rounded.SettingsApplications">
                Настройки
            </MudNavLink>

            <MudNavLink Href="profile"
                        Icon="@Icons.Material.Rounded.Person"
                        Match="NavLinkMatch.Prefix">
                @context.User.Identity?.Name
            </MudNavLink>

            <MudNavLink Href="@(NavigationManager.GetUriWithReturnUrl("Account/Logout", _currentUrl).ToString())"
                        Icon="@Icons.Material.Rounded.Logout"
                        IconColor="Color.Info"
                        Match="NavLinkMatch.Prefix">
                Выйти
            </MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="Account/Register"
                        Icon="@Icons.Material.Rounded.Person"
                        Match="NavLinkMatch.Prefix">
                Регистрация
            </MudNavLink>
            <MudNavLink Href="Account/Login"
                        Icon="@Icons.Material.Rounded.Password"
                        Match="NavLinkMatch.Prefix">
                Вход
            </MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>
